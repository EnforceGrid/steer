      tool_names:                Set<String>,
      tool_count:                Long,
      requested_tools:           Set<String>,
      budget_remaining_cents:    Long,
      budget_utilization_pct:    Long,
      injection_detected:        Bool,
      jailbreak_detected:        Bool,
      threat_detected:           Bool,
      identity_claim_detected:   Bool,
      confidential_detected:     Bool,
      exfiltration_detected:     Bool,
      exfiltration_type:         String,
      unauthorized_tool_detected:     Bool,
      tool_categories:                String,
      tool_highest_risk_category:     String,
      tool_allowlist_mode:            Bool,

      // Namespaced control facts (new — coexists with flat fields during migration)
      agent_integrity: {
          injection_detected: Bool,
          injection_score: Long,
          injection_type: String,
          jailbreak_detected: Bool,
          jailbreak_score: Long,
      },
      data_protection: {
          pii_present: Bool,
          pii_count: Long,
          confidential_detected: Bool,
          exfiltration_detected: Bool,
          exfiltration_risk: Long,
          exfiltration_url_count: Long,
      },
      content_safety: {
          threat_detected: Bool,
          threat_score: Long,
          toxicity_score: Long,
      },
      identity_safety: {
          disclosure_detected: Bool,
      },
      tool_governance: {
          unauthorized_detected: Bool,
          highest_risk: String,
      },
      supply_chain: {
          mcp_server_approved: Bool,
          mcp_server_id: String,
      },
    }
  };

